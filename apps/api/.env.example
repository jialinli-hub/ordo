# 先在 PostgreSQL 中建库（例如 CREATE DATABASE ordo;），再执行：
#   npx prisma migrate deploy
#   npm run db:seed
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ordo?schema=public"
PORT=3000
NODE_ENV=development
DINGTALK_CLIENT_ID=""
DINGTALK_CLIENT_SECRET=""
DINGTALK_CORP_ID=""
DINGTALK_AGENT_ID=""
DINGTALK_REDIRECT_URI="http://localhost:5173/dingtalk/callback"
WEB_BASE_URL="http://localhost:5173"
# 生产环境默认不在 /api/health 暴露 userTableRowCount；需要对比「API 连接的库」时设为 1
ORDO_HEALTH_DB_DETAIL=""
